# Copy to .env locally if you inject env at build time (Metro does not load .env by default).

# Full web app URL (Vite dev server or deployed SPA). No trailing slash.
# Android emulator default in code: http://10.0.2.2:5173
# iOS simulator / Windows default: http://localhost:5173
#
# Physical device on same Wi‑Fi as your PC:
# GOOUT_WEB_APP_URL=http://192.168.1.100:5173
#
# Production:
# GOOUT_WEB_APP_URL=https://app.yourdomain.com

# GOOUT_WEB_APP_URL=
