MONGODB_URI=mongodb+srv://user:password@cluster.example.mongodb.net/goout
JWT_SECRET=replace_with_a_long_random_secret
CLIENT_URL=https://go-out.vercel.app
MOBILE_APP_ORIGINS=

GOOGLE_MAPS_API_KEY=your_google_maps_server_key
GEMINI_API_KEY=your_gemini_api_key
GEMINI_API_KEY_MERCHANT=
GEMINI_MODEL=gemini-2.5-flash

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

OTP_PEPPER=
USD_INR_RATE=83
COMPARATOR_TIME_VALUE_INR_H=120
PORT=5000
HOST=0.0.0.0
MONGODB_URI=mongodb://localhost:27017/goout
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Web app URL(s) for password reset links, emails, and CORS.
# Comma-separated if you have multiple web origins (e.g. staging + prod admin).
# Vite dev default:
CLIENT_URL=http://localhost:5173

# Optional: extra browser / WebView origins that must call the API with cookies/CORS
# (comma-separated). Use when a mobile shell, Expo, or embedded browser sends an Origin header.
# Examples (uncomment and adjust):
# MOBILE_APP_ORIGINS=http://localhost:8081,http://192.168.1.10:8081
# MOBILE_APP_ORIGINS=capacitor://localhost,ionic://localhost
# MOBILE_APP_ORIGINS=https://app.yourdomain.com
# Dev only — allows any Origin (avoid in production):
# MOBILE_APP_ORIGINS=*

# Note: many native apps (React Native fetch) do not send Origin; CORS mainly affects browsers
# and WebViews. You still need correct CLIENT_URL for reset-password links in email.

# Optional: extra secret for OTP hashing (defaults to JWT_SECRET)
# OTP_PEPPER=

# Email (SMTP) — required to send login OTP and password reset emails
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="GoOut <noreply@example.com>"

GEMINI_API_KEY=your-google-gemini-api-key
# City Concierge (one Gemini request per chat message): https://aistudio.google.com/apikey
# Use a model id from https://ai.google.dev/gemini-api/docs/models (e.g. gemini-2.5-flash for new projects).
# GEMINI_MODEL=gemini-2.5-flash

# Optional: enable Google Places data source for map search parity
# GOOGLE_MAPS_API_KEY=your-google-maps-api-key
# Map search provider mode: osm | hybrid | google
# Keep "osm" for OpenStreetMap + Overpass development workflow.
MAP_PROVIDER_MODE=osm

# Comparator: ₹ opportunity cost per hour of travel time (default 180)
# COMPARATOR_TIME_VALUE_INR_H=180
